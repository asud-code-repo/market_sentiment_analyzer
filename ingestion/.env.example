# Copy to .env for local testing (gitignored). In GitHub Actions, these are
# supplied as repo secrets (Settings -> Secrets and variables -> Actions) and
# injected as env vars in the workflow — no .env file is used in CI.

# Supabase (Project Settings -> API). Service-role key required: RLS is
# deny-all by default (see supabase/migrations), and this key is the only
# one that can write to data_points.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Free signup: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Free signup: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# Optional: comma-separated Polymarket market slugs to track (from the
# market's URL, e.g. polymarket.com/event/fed-emergency-rate-cut-in-2026 ->
# slug is the last path segment). No API key required. Leave blank to skip.
POLYMARKET_SLUGS=
