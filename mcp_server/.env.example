# Copy to .env for local testing (gitignored). When launched by Claude
# Desktop, these come from the "env" block in claude_desktop_config.json
# instead — see claude_desktop_config.example.json in this folder.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Absolute path to your local portfolio file (see local_state/portfolio.example.yaml).
# Never a path inside a networked/synced folder that isn't actually local-only.
PORTFOLIO_PATH=C:\Users\YOUR_USER\local_repo\market_sentiment_analyzer\local_state\portfolio.yaml

# Absolute path to your local BrokerageLink watchlist file (see
# local_state/brokeragelink_watchlist.example.yaml). Same local-only rule as above.
WATCHLIST_PATH=C:\Users\YOUR_USER\local_repo\market_sentiment_analyzer\local_state\brokeragelink_watchlist.yaml
